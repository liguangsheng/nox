{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Nox",
  "scopeName": "source.nox",
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#numbers" },
    { "include": "#keywords" },
    { "include": "#types" },
    { "include": "#functions" },
    { "include": "#operators" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        { "name": "comment.line.double-slash.nox", "match": "//.*$" }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.triple.nox",
          "begin": "\"\"\"",
          "end": "\"\"\"",
          "patterns": [{ "include": "#interpolation" }]
        },
        {
          "name": "string.quoted.raw.nox",
          "begin": "r\"",
          "end": "\""
        },
        {
          "name": "string.quoted.double.nox",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            { "name": "constant.character.escape.nox", "match": "\\\\[\\\\\"n$t]" },
            { "include": "#interpolation" }
          ]
        },
        {
          "name": "string.quoted.single.nox",
          "begin": "'",
          "end": "'",
          "patterns": [{ "name": "constant.character.escape.nox", "match": "\\\\[\\\\'n]" }]
        }
      ]
    },
    "interpolation": {
      "patterns": [
        {
          "name": "meta.interpolation.nox",
          "begin": "\\$\\{",
          "end": "\\}",
          "patterns": [{ "include": "$self" }]
        }
      ]
    },
    "numbers": {
      "patterns": [
        { "name": "constant.numeric.hex.nox", "match": "\\b0x[0-9A-Fa-f_]+\\b" },
        { "name": "constant.numeric.binary.nox", "match": "\\b0b[01_]+\\b" },
        { "name": "constant.numeric.octal.nox", "match": "\\b0o[0-7_]+\\b" },
        { "name": "constant.numeric.float.nox", "match": "\\b[0-9][0-9_]*\\.[0-9][0-9_]*\\b" },
        { "name": "constant.numeric.integer.nox", "match": "\\b[0-9][0-9_]*\\b" }
      ]
    },
    "keywords": {
      "patterns": [
        { "name": "keyword.control.nox", "match": "\\b(if|else|while|for|in|match|return|break|continue)\\b" },
        { "name": "keyword.declaration.nox", "match": "\\b(let|fn|record|enum|type|import|export|as)\\b" },
        { "name": "constant.language.nox", "match": "\\b(true|false|null|none)\\b" }
      ]
    },
    "types": {
      "patterns": [
        { "name": "storage.type.nox", "match": "\\b(int|float|bool|str|json|option|result|map)\\b" }
      ]
    },
    "functions": {
      "patterns": [
        { "name": "entity.name.function.nox", "match": "(?<=\\bfn\\s+)[A-Za-z_][A-Za-z0-9_]*" },
        { "name": "support.function.builtin.nox", "match": "\\b(len|contains|map_get|map_keys|map_values|map_has|map_size|some|ok|err|args|print)\\b" }
      ]
    },
    "operators": {
      "patterns": [
        { "name": "keyword.operator.nox", "match": "(==|!=|<=|>=|&&|\\|\\||<<|>>|\\.\\.|=>|[-+*/%<>=!~&|^?:])" }
      ]
    }
  }
}
