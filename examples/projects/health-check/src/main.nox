import "checks.nox";

let manifest_ok: bool = file_present("nox.toml");

let user_label: str = env_or_default("USER", "unknown");

let flags: HealthFlags = HealthFlags {manifest_ok: manifest_ok, user_present: len(user_label) > 0};

let healthy_count: int = flags.count_present();

if (healthy_count == 2) {
    "health-check: ok";
} else {
    "health-check: degraded";
}
