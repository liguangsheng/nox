record SurfaceRecord {
    id: int,
    name: str,
    active: bool,
}

enum SurfaceEnum {
    Number(int),
    Name(str),
    Flag(bool),
}

fn surface_record(id: int, name: str, active: bool) -> SurfaceRecord {
    return SurfaceRecord { id: id, name: name, active: active };
}

fn surface_enum_int(value: int) -> SurfaceEnum {
    return SurfaceEnum.Number(value);
}

fn surface_enum_str(value: str) -> SurfaceEnum {
    return SurfaceEnum.Name(value);
}

fn surface_enum_bool(value: bool) -> SurfaceEnum {
    return SurfaceEnum.Flag(value);
}

fn surface_record_from_json(id: json, name: json, active: json) -> result[SurfaceRecord, str] {
    return ok(SurfaceRecord { id: 1, name: "surface", active: true });
}

fn surface_enum_from_json(value: json) -> result[SurfaceEnum, str] {
    return ok(SurfaceEnum.Number(1));
}

fn surface_enum_property(value: SurfaceEnum) -> bool {
    return true;
}

fn surface_double(value: int) -> int {
    return value * 2;
}

fn surface_some_increment(value: int) -> option[int] {
    return some(value + 1);
}

fn surface_positive(value: int) -> result[int, str] {
    if (value > 0) {
        return ok(value);
    } else {
        return err("not-positive");
    }
}

fn surface_prefix(value: str) -> str {
    return "error:" + value;
}

